{
  "inputs": [
    {
      "type": "promptString",
      "id": "supabase-access-token",
      "description": "Supabase personal access token",
      "password": true,
      "default": "mxffgjihhwrhytbfkixy"
    },
    {
      "type": "promptString",
      "id": "supabase-project-ref",
      "description": "Supabase project reference (e.g., your-project-ref)",
      "password": true
    }
  ],
  "servers": {
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref",
        "${input:supabase-project-ref}"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${input:supabase-access-token}",
        "SUPABASE_PROJECT_REF": "${input:supabase-project-ref}"
      }
    }
  }
}
